generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  firstName             String
  lastName              String
  phone                 String    @unique
  role                  String    @default("buyer")
  verificationTier      String    @default("NONE")
  isActive              Boolean   @default(true)
  isVerified            Boolean   @default(false)
  isBanned              Boolean   @default(false)
  banReason             String?
  bannedAt              DateTime?
  bannedBy              String?
  bvnVerified           Boolean   @default(false)
  bvnHash               String?
  ninVerified           Boolean   @default(false)
  ninHash               String?
  govtIdType            String?
  govtIdVerified        Boolean   @default(false)
  govtIdUrl             String?
  notaryVerified        Boolean   @default(false)
  notaryDocUrl          String?
  notaryVerifiedAt      DateTime?
  phoneVerified         Boolean   @default(false)
  paystackRecipientCode String?
  bankAccountName       String?
  bankAccountNumber     String?
  bankCode              String?
  fraudScore            Int       @default(0)
  fraudFlags            String[]  @default([])
  lastLoginAt           DateTime?
  lastLoginIp           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  profile            UserProfile?
  properties         Property[]
  buyTransactions    Transaction[]      @relation("buyer")
  sellTransactions   Transaction[]      @relation("seller")
  escrowsBuyer       Escrow[]           @relation("escrowBuyer")
  escrowsSeller      Escrow[]           @relation("escrowSeller")
  splitBuyer         SplitEscrow[]      @relation("splitBuyer")
  splitSeller        SplitEscrow[]      @relation("splitSeller")
  favorites          Favorite[]
  notifications      Notification[]
  supportTickets     SupportTicket[]
  otps               Otp[]
  passwordResets     PasswordReset[]
  legalAcceptances   LegalAcceptance[]
  chatParticipants   ChatParticipant[]
  multiSigSignatures MultiSigSignature[]
  auditLogs          AuditLog[]         @relation("auditUser")
  sentMessages       ChatMessage[]      @relation("messageSender")
  sessionLogs        SessionLog[]

  @@map("users")
}

model UserProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  displayName   String
  bio           String?
  avatar        String?
  state         String?
  lga           String?
  address       String?
  website       String?
  cacNumber     String?
  licenseNumber String?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Otp {
  id        String    @id @default(cuid())
  userId    String
  otp       String
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Property {
  id               String    @id @default(cuid())
  title            String
  description      String
  price            Float
  propertyType     String
  listingType      String
  status           String    @default("pending")
  state            String
  lga              String
  address          String
  landmark         String?
  bedrooms         Int?
  bathrooms        Int?
  toilets          Int?
  size             Float?
  sizeUnit         String?   @default("sqm")
  amenities        String[]  @default([])
  latitude         Float?
  longitude        Float?
  isFeatured       Boolean   @default(false)
  isVerified       Boolean   @default(false)
  titleDocVerified Boolean   @default(false)
  moderationStatus String    @default("review_required")
  moderationData   Json?
  moderationScore  Int?
  moderatedBy      String?
  moderatedAt      DateTime?
  moderationReason String?
  viewCount        Int       @default(0)
  ownerId          String
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner        User               @relation(fields: [ownerId], references: [id])
  images       PropertyImage[]
  documents    PropertyDocument[]
  transactions Transaction[]
  views        PropertyView[]
  favorites    Favorite[]
  escrows      Escrow[]
  splitEscrows SplitEscrow[]

  @@index([state, status])
  @@index([price])
  @@index([ownerId])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model PropertyDocument {
  id           String    @id @default(cuid())
  propertyId   String
  name         String
  url          String
  documentType String
  isPublic     Boolean   @default(false)
  isVerified   Boolean   @default(false)
  verifiedBy   String?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_documents")
}

model PropertyView {
  id         String   @id @default(cuid())
  propertyId String
  userId     String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_views")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Transaction {
  id               String    @id @default(cuid())
  propertyId       String
  buyerId          String
  sellerId         String
  agentId          String?
  amount           Float
  type             String
  status           String    @default("initiated")
  paymentPlan      String    @default("full")
  paymentReference String?
  paidAt           DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  property    Property        @relation(fields: [propertyId], references: [id])
  buyer       User            @relation("buyer", fields: [buyerId], references: [id])
  seller      User            @relation("seller", fields: [sellerId], references: [id])
  escrow      Escrow?
  splitEscrow SplitEscrow?
  documents   LegalDocument[]
  auditLogs   AuditLog[]
  chatRoom    ChatRoom?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("transactions")
}

model Escrow {
  id                 String    @id @default(cuid())
  transactionId      String    @unique
  buyerId            String
  sellerId           String
  propertyId         String
  agentId            String?
  totalDeposited     Float     @default(0)
  platformFee        Float     @default(0)
  agentCommission    Float     @default(0)
  vatAmount          Float     @default(0)
  whtAmount          Float     @default(0)
  netSellerAmount    Float     @default(0)
  status             String    @default("initiated")
  multiSigStatus     String    @default("pending")
  paymentReference   String?
  fundedAt           DateTime?
  inspectionPassed   Boolean?
  docsVerified       Boolean   @default(false)
  releaseRequestedAt DateTime?
  releasedAt         DateTime?
  releasedBy         String?
  payoutReference    String?
  refundedAt         DateTime?
  refundReason       String?
  disputeId          String?
  timeline           Json?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  transaction        Transaction        @relation(fields: [transactionId], references: [id])
  property           Property           @relation(fields: [propertyId], references: [id])
  buyer              User               @relation("escrowBuyer", fields: [buyerId], references: [id])
  seller             User               @relation("escrowSeller", fields: [sellerId], references: [id])
  multiSigSignatures MultiSigSignature[]
  splitReceipts      SplitReceipt[]
  disputes           Dispute[]

  @@map("escrows")
}

model MultiSigSignature {
  id            String   @id @default(cuid())
  escrowId      String
  signerId      String
  signerRole    String
  signedAt      DateTime @default(now())
  signatureHash String
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  escrow        Escrow   @relation(fields: [escrowId], references: [id])
  signer        User     @relation(fields: [signerId], references: [id])

  @@unique([escrowId, signerRole])
  @@map("multisig_signatures")
}

model SplitReceipt {
  id                 String    @id @default(cuid())
  escrowId           String
  transactionId      String?
  totalAmount        Float
  platformFee        Float
  platformFeeRef     String?
  agentCommission    Float
  agentCommissionRef String?
  vatAmount          Float
  vatRef             String?
  whtAmount          Float
  whtRef             String?
  netSellerAmount    Float
  netSellerRef       String?
  status             String    @default("pending")
  processedAt        DateTime?
  failureReason      String?
  retryCount         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  escrow             Escrow    @relation(fields: [escrowId], references: [id])

  @@map("split_receipts")
}

model SplitEscrow {
  id                String    @id @default(cuid())
  transactionId     String?   @unique
  propertyId        String
  buyerId           String
  sellerId          String
  totalAmount       Float
  downPayment       Float
  balance           Float
  installmentAmount Float
  totalInstallments Int
  paidInstallments  Int       @default(0)
  schedule          Json
  status            String    @default("active")
  intervalDays      Int       @default(30)
  nextDueDate       DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  property    Property    @relation(fields: [propertyId], references: [id])
  buyer       User        @relation("splitBuyer", fields: [buyerId], references: [id])
  seller      User        @relation("splitSeller", fields: [sellerId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@map("split_escrows")
}

model Vault {
  id            String           @id @default(cuid())
  name          String           @unique
  balance       Float            @default(0)
  totalIn       Float            @default(0)
  totalOut      Float            @default(0)
  currency      String           @default("NGN")
  lastUpdatedAt DateTime         @default(now())
  createdAt     DateTime         @default(now())
  transactions  VaultTransaction[]

  @@map("vaults")
}

model VaultTransaction {
  id          String   @id @default(cuid())
  vaultId     String
  amount      Float
  type        String
  reference   String?
  description String?
  sourceId    String?
  createdAt   DateTime @default(now())
  vault       Vault    @relation(fields: [vaultId], references: [id])

  @@map("vault_transactions")
}

model ChatRoom {
  id            String          @id @default(cuid())
  transactionId String?         @unique
  name          String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  transaction   Transaction?    @relation(fields: [transactionId], references: [id])
  participants  ChatParticipant[]
  messages      ChatMessage[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("chat_participants")
}

model ChatMessage {
  id              String    @id @default(cuid())
  roomId          String
  senderId        String
  content         String
  originalContent String?
  messageType     String    @default("text")
  isRedacted      Boolean   @default(false)
  redactedAt      DateTime?
  redactedReason  String?
  redactedBy      String?
  fileUrl         String?
  fileName        String?
  isRead          Boolean   @default(false)
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  room            ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender          User      @relation("messageSender", fields: [senderId], references: [id])

  @@index([roomId])
  @@map("chat_messages")
}

model LegalAcceptance {
  id           String   @id @default(cuid())
  userId       String
  documentType String
  version      String
  acceptedAt   DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id])

  @@map("legal_acceptances")
}

model LegalDocument {
  id             String      @id @default(cuid())
  transactionId  String
  type           String
  content        String
  version        String
  status         String      @default("draft")
  signedByBuyer  Boolean     @default(false)
  buyerSignedAt  DateTime?
  signedBySeller Boolean     @default(false)
  sellerSignedAt DateTime?
  signedByNotary Boolean     @default(false)
  notarySignedAt DateTime?
  createdAt      DateTime    @default(now())
  transaction    Transaction @relation(fields: [transactionId], references: [id])

  @@map("legal_documents")
}

model Dispute {
  id           String    @id @default(cuid())
  escrowId     String
  initiatedBy  String
  respondentId String?
  reason       String
  evidence     Json      @default("[]")
  status       String    @default("open")
  assignedTo   String?
  resolution   String?
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  escrow       Escrow    @relation(fields: [escrowId], references: [id])

  @@map("disputes")
}

model AuditLog {
  id            String    @id @default(cuid())
  action        String
  userId        String?
  transactionId String?
  resourceType  String?
  resourceId    String?
  description   String
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  user          User?     @relation("auditUser", fields: [userId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String    @default("info")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  data      Json?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SupportTicket {
  id           String    @id @default(cuid())
  userId       String
  ticketNumber String    @unique
  subject      String
  message      String
  category     String    @default("general")
  priority     String    @default("normal")
  status       String    @default("open")
  assignedTo   String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])

  @@map("support_tickets")
}

model SessionLog {
  id           String    @id @default(cuid())
  userId       String
  event        String
  ipAddress    String?
  userAgent    String?
  success      Boolean   @default(true)
  failReason   String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("session_logs")
}
