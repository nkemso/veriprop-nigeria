{
  "version": 2,
  "buildCommand": "node_modules/.bin/vite build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://veriprop-nigeria-production.up.railway.app",
    "VITE_APP_NAME": "VeriProp Nigeria"
  }
}
