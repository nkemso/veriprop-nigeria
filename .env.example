# ============================================
# VERIPRO NIGERIA - ENVIRONMENT VARIABLES
# ============================================

# App
NODE_ENV=development
PORT=5000
APP_NAME=VeriPro Nigeria
APP_URL=https://veriproNigeria.com
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/veripro_nigeria
DIRECT_URL=postgresql://username:password@localhost:5432/veripro_nigeria

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=your_256_bit_encryption_key_here
BCRYPT_ROUNDS=12

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@veripronigeria.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=VeriPro Nigeria <noreply@veripronigeria.com>

# SMS (Termii / Twilio)
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=VeriPro
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# Paystack (Nigeria Payments)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Flutterwave (Nigeria Payments)
FLUTTERWAVE_SECRET_KEY=FLWSECK_your_secret_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your_public_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# Escrow
ESCROW_BANK_ACCOUNT=your_escrow_bank_account
ESCROW_BANK_CODE=your_bank_code

# NIN / BVN Verification (NIBSS / Smile Identity)
NIBSS_API_KEY=your_nibss_api_key
SMILE_IDENTITY_API_KEY=your_smile_identity_api_key
SMILE_IDENTITY_PARTNER_ID=your_partner_id

# CAC Verification
CAC_API_KEY=your_cac_api_key
CAC_API_URL=https://efts.cac.gov.ng/api

# AI Moderation (OpenAI)
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o

# Google Maps / Geocoding
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Redis (Caching & Sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/veripro.log

# Admin
ADMIN_EMAIL=admin@veripronigeria.com
ADMIN_PASSWORD=ChangeThisImmediately!

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://veripronigeria.com,https://www.veripronigeria.com

# Webhook
WEBHOOK_SECRET=your_webhook_secret_key
