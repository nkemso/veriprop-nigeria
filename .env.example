# ================================================================
# VERIPROP NIGERIA — ENVIRONMENT VARIABLES REFERENCE
# ================================================================
# Copy this to .env — NEVER commit .env to GitHub
# STATUS: [REQUIRED] [IMPORTANT] [OPTIONAL] [FREE-NO-KEY]
# ================================================================

# ── 1. CORE ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_NAME=VeriProp Nigeria
APP_URL=https://your-railway-url.up.railway.app
FRONTEND_URL=https://your-vercel-url.vercel.app
ALLOWED_ORIGINS=https://your-vercel-url.vercel.app

# ── 2. DATABASE (Railway auto-fills these) ───────────────────────
# [REQUIRED] - Railway: Variables → Add Reference → Postgres
DATABASE_URL=postgresql://user:pass@host:5432/db
DIRECT_URL=postgresql://user:pass@host:5432/db

# ── 3. JWT AUTH ──────────────────────────────────────────────────
# [REQUIRED] Generate: openssl rand -base64 32
JWT_SECRET=generate-random-32-plus-characters-here
JWT_REFRESH_SECRET=another-random-32-plus-characters-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── 4. REDIS (Railway auto-fills) ───────────────────────────────
# [OPTIONAL] Railway: Variables → Add Reference → Redis
REDIS_URL=redis://default:password@host:6379
REDIS_PASSWORD=

# ── 5. PAYSTACK (Nigeria Payments) ──────────────────────────────
# [IMPORTANT] Get at: dashboard.paystack.com → Settings → API Keys
# Use sk_test_ for dev, sk_live_ for production
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here
ESCROW_BANK_ACCOUNT=your_escrow_account_number
ESCROW_BANK_CODE=your_bank_code

# ── 6. AI MODERATION ────────────────────────────────────────────
# [IMPORTANT] Set AI_PROVIDER then add matching key
# Options: groq | qwen | deepseek | gemini | local
AI_PROVIDER=groq

# GROQ - FREE forever (console.groq.com)
GROQ_API_KEY=your_groq_key_from_console_groq_com
GROQ_MODEL=llama-3.1-8b-instant

# QWEN/Alibaba - FREE forever (dashscope.aliyuncs.com)
QWEN_API_KEY=your_qwen_key_here
QWEN_MODEL=qwen-plus

# DEEPSEEK - Ultra cheap $0.0001/1k tokens (platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# GEMINI/Google - FREE limited 15req/min (aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── 7. MAPS ──────────────────────────────────────────────────────
# [FREE-NO-KEY] OpenStreetMap is the default - no key needed!
# Optional Mapbox token for enhanced styles (account.mapbox.com)
# Free tier: 50,000 requests/month
MAPBOX_TOKEN=your_optional_mapbox_token_here

# ── 8. IDENTITY VERIFICATION (KYC) ──────────────────────────────
# [OPTIONAL] Smile Identity - Nigerian biometric verification
# Get at: developerportal.smileidentity.com
SMILE_IDENTITY_API_KEY=your_smile_identity_key
SMILE_IDENTITY_PARTNER_ID=your_partner_id

# [OPTIONAL] NIBSS - BVN verification
NIBSS_API_KEY=your_nibss_api_key

# [OPTIONAL] CAC - Company verification
CAC_API_KEY=your_cac_api_key
CAC_API_URL=https://efts.cac.gov.ng/api

# ── 9. FILE STORAGE - Cloudinary ─────────────────────────────────
# [IMPORTANT] For property images (cloudinary.com - free 25GB)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── 10. EMAIL ────────────────────────────────────────────────────
# [OPTIONAL] For OTP, receipts, notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@veripronigeria.com
SMTP_PASS=your_smtp_app_password
EMAIL_FROM=VeriProp Nigeria <noreply@veripronigeria.com>

# ── 11. SMS - Termii (Nigeria) ───────────────────────────────────
# [OPTIONAL] For phone OTP (termii.com)
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=VeriProp

# Twilio alternative
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

# ── 12. SECURITY ─────────────────────────────────────────────────
# [OPTIONAL] Generate: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_key
BCRYPT_ROUNDS=12

# ── 13. RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── 14. ADMIN ────────────────────────────────────────────────────
# After creating account, run in Railway DB:
# UPDATE users SET role='super_admin' WHERE email='your@email.com';
ADMIN_EMAIL=admin@veripronigeria.com
ADMIN_PASSWORD=YourVeryStrongAdminPassword

# ── 15. LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/veripro.log

# ── 16. FRONTEND ONLY (Set in Vercel Dashboard) ──────────────────
# Vercel: Project → Settings → Environment Variables
VITE_API_URL=https://your-railway-url.up.railway.app
VITE_APP_NAME=VeriProp Nigeria
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key

# ================================================================
# RAILWAY QUICK SETUP (minimum required to launch):
# ================================================================
# DATABASE_URL      = ${{Postgres.DATABASE_URL}}
# DIRECT_URL        = ${{Postgres.DATABASE_URL}}
# REDIS_URL         = ${{Redis.REDIS_URL}}
# JWT_SECRET        = (random 32+ chars)
# JWT_REFRESH_SECRET= (random 32+ chars)
# NODE_ENV          = production
# PORT              = 5000
# FRONTEND_URL      = https://your-vercel-url.vercel.app
# ALLOWED_ORIGINS   = https://your-vercel-url.vercel.app
# AI_PROVIDER       = groq
# GROQ_API_KEY      = (from console.groq.com - free)
# PAYSTACK_SECRET_KEY = sk_live_... (from dashboard.paystack.com)
# PAYSTACK_PUBLIC_KEY = pk_live_...
# ================================================================
