# ================================================================
# VERIPROP NIGERIA — ENVIRONMENT VARIABLES
# ================================================================

# ── APP ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_URL=https://veriprop-nigeria.vercel.app

# ── DATABASE (Railway PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/veriprop
DIRECT_URL=postgresql://user:pass@host:5432/veriprop

# ── REDIS (Railway Redis) ────────────────────────────────────
REDIS_URL=redis://default:pass@host:6379

# ── AUTH ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-jwt-secret-key

# ════════════════════════════════════════════════════════════════
# ⛔ CRITICAL — DIDIT KYC (REQUIRED FOR VERIFICATION)
# ════════════════════════════════════════════════════════════════
# Sign up at: https://business.didit.me (FREE, no credit card)
# 500 FREE verifications/month forever
#
# WITHOUT this key, ALL identity verification (NIN, biometric)
# will FAIL. This is intentional — no fake verification allowed.
# ════════════════════════════════════════════════════════════════
DIDIT_API_KEY=your_didit_api_key_here
DIDIT_WORKFLOW_ID=your_workflow_id_here
DIDIT_WEBHOOK_SECRET=your_webhook_secret_here

# ── EMAIL (Resend) ────────────────────────────────────────
# Sign up: resend.com (no credit card for free tier)
# Free: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ── PUSH NOTIFICATIONS (Firebase Cloud Messaging V1) ─────
# Setup: console.firebase.google.com → Project Settings
#        → Service Accounts → Generate new private key
# Free: UNLIMITED push notifications forever
#
# Option A: Full service account JSON (recommended)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"veriprop-nigeria",...}
#
# Option B: Individual values from the JSON file
# FIREBASE_PROJECT_ID=veriprop-nigeria-xxxxx
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@veriprop-nigeria-xxxxx.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n" 

# ── IDENTITY VERIFICATION (NIN real government checks) ───
# Default provider: ninbvnportal (NIN ₦150)
# Switch to prembly for cheaper rates (NIN ₦80)
IDENTITY_PROVIDER=ninbvnportal

# Provider 1: NINBVNPortal (default)
# Signup: ninbvnportal.com.ng (any email)
NINBVN_API_KEY=your_api_key_here

# Provider 2: Prembly/IdentityPass (cheapest — switch later)
# Signup: myidentitypass.com (company email required)
# To activate: set IDENTITY_PROVIDER=prembly
# PREMBLY_API_KEY=your_api_key_here
# PREMBLY_APP_ID=your_app_id_here

# ── TELEGRAM BOT (FREE unlimited) ────────────────────────
# Setup: Message @BotFather on Telegram → /newbot → get token
# Free: Unlimited notifications, login, OTP, channel posts
TELEGRAM_BOT_TOKEN=7123456789:AAHxyz_your_bot_token_here
TELEGRAM_CHANNEL_ID=@VeriPropNigeria

# ── PAYMENTS (Paystack) ─────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx

# ── AI MODERATION ────────────────────────────────────────────
# Options: groq | qwen | deepseek | gemini | local
AI_PROVIDER=groq
GROQ_API_KEY=gsk_xxx

# ── MEDIA (Cloudinary) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://veriprop-nigeria.vercel.app,http://localhost:5173
