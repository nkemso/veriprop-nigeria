# Core runtime
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/veriprop
CORS_ORIGIN=https://www.veriprop.com.ng
JWT_SECRET=your_jwt_signing_secret
OPS_SYSTEM_TOKEN=your_ops_system_token

# TRUST & IDENTITY (TIER 1-3)
NIBSS_BVN_API_KEY=your_nibss_bvn_key_here
SMILEID_URL=https://api.smileid.com/v1
MFA_TOKEN=your_mfa_sms_gateway_token

# Backward-compatible aliases
ID_VERIFICATION_SERVICE_URL=https://api.smileid.com/v1
ID_VERIFICATION_SECRET=your_smileid_secret_here
MFA_GATEWAY_TOKEN=your_mfa_sms_gateway_token

# FINANCIAL & ESCROW LOGIC (AUTOMATED SPLITTING)
PAYMENT_SECRET=your_paystack_or_flutterwave_secret
PLATFORM_WALLET=your_platform_bank_account_or_wallet_ref
TAX_ID=your_firs_tax_remittance_wallet_ref
ESCROW_KEY=your_master_escrow_encryption_key

# Backward-compatible aliases
PAYMENT_GATEWAY_SECRET=your_paystack_or_flutterwave_secret
PLATFORM_WALLET_ID=your_platform_bank_account_or_wallet_ref
TAX_REMITTANCE_ID=your_firs_tax_remittance_wallet_ref
ESCROW_VAULT_KEY=your_master_escrow_encryption_key

# VETPRO AI & SECURITY PROTOCOLS
AI_API_KEY=your_openai_or_anthropic_api_key
CHAT_ENCRYPTION_KEY=your_chat_encryption_key_here
WEBSITE_URL=https://www.veriprop.com.ng

# Backward-compatible alias
AI_SERVICE_API_KEY=your_openai_or_anthropic_api_key
